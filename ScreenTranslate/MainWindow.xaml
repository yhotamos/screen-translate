<Window x:Class="ScreenTranslate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScreenTranslate"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- ボタン -->
                <RowDefinition Height="*"/>
                <!-- 翻訳元 -->
                <RowDefinition Height="*"/>
                <!-- 翻訳後 -->
            </Grid.RowDefinitions>

            <!-- ボタン -->
            <WrapPanel Grid.Row="0">
                <Button Content="OCR実行"
                Click="OnOcrClick"
                Height="40"
                Width="120"
                Margin="0,0,10,0"/>
            </WrapPanel>

            <!-- 翻訳元 -->
            <TextBox x:Name="SourceBox"
             Grid.Row="1"
             Margin="0,10,0,5"
             AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto"
             TextWrapping="Wrap"/>

            <!-- 翻訳後 -->
            <TextBox x:Name="ResultBox"
             Grid.Row="2"
             Margin="0,5,0,0"
             AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto"
             TextWrapping="Wrap"/>
        </Grid>

    </Grid>
</Window>
